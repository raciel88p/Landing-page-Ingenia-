---
import { Navbar } from '../components/navbar.tsx';
import { Hero } from '../components/hero.tsx';
import { WhatsAppButton } from '../components/whatsapp-button.tsx';
import { StatsBar } from '../components/stats-bar.tsx';
import { Gallery } from '../components/gallery.tsx';
import { SocialProof } from '../components/social-proof.tsx';
import { HowItWorks } from '../components/how-it-works.tsx';
import { Features } from '../components/features.tsx';
import { Pricing } from '../components/pricing.tsx';
import { MidCTA } from '../components/mid-cta.tsx';
import { Testimonials } from '../components/testimonials.tsx';
import { Comparison } from '../components/comparison.tsx';
import { TestimonialQuotes } from '../components/testimonial-quotes.tsx';
import { FAQ } from '../components/faq.tsx';
import { FinalCTA } from '../components/final-cta.tsx';
import { Footer } from '../components/footer.tsx';
import { Toaster } from '../components/ui/toaster.tsx';
import { GoogleTagmanager } from '@digi4care/astro-google-tagmanager';
import '../index.css';
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-11BCP6TVK4" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-11BCP6TVK4');
    </script>
    <GoogleTagmanager id="GTM-KQQDG3LP" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />

    <title>Camisas Tipo Columbia para Empresas en Costa Rica | Ingenia</title>
    <meta name="description" content="Uniformes corporativos tipo Columbia con bordado personalizado para su empresa en Costa Rica. Producción local, entrega a todo el país. ¡Solicite su cotización hoy!" />
    <meta name="keywords" content="camisas columbia, uniformes corporativos, costa rica, bordado personalizado, ropa de trabajo, camisas tipo columbia para empresas" />

    <!-- Google SEO & Indexing -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <!-- Descomentar y añadir el código provisto por Google Search Console si se requiere validación de propiedad -->
    <!-- <meta name="google-site-verification" content="TU_CODIGO_DE_VERIFICACION_AQUI" /> -->

    <!-- Canonical -->
    <link rel="canonical" href="https://ingenia.cr/" />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ingenia.cr/" />
    <meta property="og:title" content="Camisas Tipo Columbia para Empresas en Costa Rica | Ingenia" />
    <meta property="og:description" content="Uniformes corporativos tipo Columbia con bordado personalizado para su empresa en Costa Rica. Producción local, entrega a todo el país. ¡Solicite su cotización hoy!" />
    <meta property="og:image" content="https://ingenia.cr/images/hero-shirt.jpeg" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content="Ingenia" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Camisas Tipo Columbia para Empresas en Costa Rica | Ingenia" />
    <meta name="twitter:description" content="Uniformes corporativos con bordado personalizado. Producción local en Costa Rica. ¡Solicite su cotización hoy!" />
    <meta name="twitter:image" content="https://ingenia.cr/images/hero-shirt.jpeg" />

    <!-- Schema Markup: LocalBusiness + Product -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": "https://ingenia.cr/#business",
          "name": "Ingenia",
          "url": "https://ingenia.cr",
          "telephone": "+50689437109",
          "email": "ventas@ingenia.cr",
          "description": "Especialistas en la confección y personalización de camisas tipo Columbia para empresas en Costa Rica.",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Concepción",
            "addressLocality": "San Rafael",
            "addressRegion": "Heredia",
            "addressCountry": "CR"
          },
          "areaServed": {
            "@type": "Country",
            "name": "Costa Rica"
          },
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+50689437109",
            "contactType": "sales",
            "availableLanguage": "Spanish",
            "contactOption": "TollFree"
          },
          "sameAs": []
        },
        {
          "@type": "Product",
          "@id": "https://ingenia.cr/#product",
          "name": "Camisas Tipo Columbia Corporativas con Bordado",
          "description": "Uniformes corporativos estilo Columbia con bordado personalizado del logotipo de su empresa. Confeccionadas con tela técnica de alto rendimiento, ideales para equipos de trabajo en campo, ventas y atención al cliente.",
          "brand": {
            "@type": "Brand",
            "name": "Ingenia"
          },
          "category": "Uniformes Corporativos",
          "offers": {
            "@type": "Offer",
            "priceCurrency": "CRC",
            "availability": "https://schema.org/InStock",
            "seller": {
              "@id": "https://ingenia.cr/#business"
            },
            "url": "https://ingenia.cr/",
            "description": "Solicite su cotización personalizada. Precio según cantidad y personalización."
          },
          "image": "https://ingenia.cr/images/hero-shirt.jpeg",
          "additionalProperty": [
            {
              "@type": "PropertyValue",
              "name": "Personalización",
              "value": "Bordado con logotipo corporativo"
            },
            {
              "@type": "PropertyValue",
              "name": "Producción",
              "value": "Local en Costa Rica"
            },
            {
              "@type": "PropertyValue",
              "name": "Entrega",
              "value": "Todo el país"
            }
          ]
        }
      ]
    }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preconnect para recursos externos -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- Fuentes: carga no bloqueante (print trick) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      />
    </noscript>

    <!-- Fuente por defecto mientras cargan (evita FOUT) -->
    <style>
      body { font-family: system-ui, -apple-system, sans-serif; }
    </style>
  </head>
  <body>
    <div id="root">
      <div class="min-h-screen bg-background text-foreground">
        <Navbar client:load />
        <main>
          <Hero client:load />
          <StatsBar client:visible />
          <Gallery client:visible />
          <SocialProof client:visible />
          <HowItWorks client:visible />
          <Features client:visible />
          <Pricing client:visible />
          <MidCTA client:visible />
          <Comparison client:visible />
          <Testimonials client:visible />
          <TestimonialQuotes client:visible />
          <FAQ client:visible />
          <FinalCTA client:visible />
        </main>
        <Footer client:visible />
        <WhatsAppButton client:load />
      </div>
      <Toaster client:load />
    </div>
  </body>
</html>